# URL publica del proyecto Supabase de NordArrel.
NEXT_PUBLIC_SUPABASE_URL=

# Clave anon publica. Sirve para iniciar la app.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clave privada del servidor. No se pone nunca en la web publica.
SUPABASE_SERVICE_ROLE_KEY=

# Usaremos public para hacerlo simple y visible en Supabase.
NEXT_PUBLIC_SUPABASE_SCHEMA=public

# URL local de la web publica.
NEXT_PUBLIC_WEB_URL=http://localhost:6001
